    <ItemGroup>
      <_CdpDriverDeployFiles Include="$(TargetPath)" />
      <_CdpDriverDeployFiles Include="$(DriverPackageDir)CdpDriver.inf" Condition="Exists('$(DriverPackageDir)CdpDriver.inf')" />
      <_CdpDriverDeployFiles Include="$(MSBuildProjectDirectory)\CdpDriver.inf" Condition="!Exists('$(DriverPackageDir)CdpDriver.inf')" />
      <_CdpDriverDeployFiles Include="$(DriverPackageDir)*.cat" Condition="Exists('$(DriverPackageDir)')" />
    </ItemGroup>
    <MakeDir Directories="$(ConsoleDeployDir)" />
    <Copy SourceFiles="@(_CdpDriverDeployFiles)" DestinationFolder="$(ConsoleDeployDir)" SkipUnchangedFiles="false" />
